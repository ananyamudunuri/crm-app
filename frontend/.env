# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL (when running locally)
REACT_APP_API_URL=http://localhost:8000/api/v1

# Alternative: When using Docker Compose
# REACT_APP_API_URL=http://backend:8000/api/v1

# ============================================
# APPLICATION CONFIGURATION
# ============================================
REACT_APP_APP_NAME="CRM Platform"
REACT_APP_ENVIRONMENT=development
REACT_APP_VERSION=1.0.0

# ============================================
# FEATURE FLAGS
# ============================================
REACT_APP_ENABLE_DEBUG_PANEL=true
REACT_APP_ENABLE_MOCK_API=false
REACT_APP_ENABLE_DEV_TOOLS=true

# ============================================
# AUTHENTICATION (Optional - for future implementation)
# ============================================
REACT_APP_AUTH_ENABLED=false
REACT_APP_AUTH0_DOMAIN=your-domain.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-client-id

# ============================================
# ANALYTICS (Optional)
# ============================================
REACT_APP_GA_TRACKING_ID=UA-XXXXXXXXX-X
REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# UI CONFIGURATION
# ============================================
REACT_APP_DEFAULT_PAGE_SIZE=20
REACT_APP_MAX_PAGE_SIZE=100
REACT_APP_DEFAULT_THEME=light

# ============================================
# TIMEOUTS
# ============================================
REACT_APP_API_TIMEOUT=30000
REACT_APP_TOAST_DURATION=5000

# ============================================
# FILE UPLOADS (Optional)
# ============================================
REACT_APP_MAX_FILE_SIZE_MB=5
REACT_APP_ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf,.doc,.docx